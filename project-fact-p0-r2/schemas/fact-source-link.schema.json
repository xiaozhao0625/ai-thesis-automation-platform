{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fact-source-link.schema.json",
  "title": "FactSourceLink",
  "type": "object",
  "additionalProperties": false,
  "required": ["source_link_id", "fact_key", "canonical_value", "original_value", "confidence", "locator"],
  "properties": {
    "source_link_id": {"type": "string", "minLength": 1},
    "fact_key": {"type": "string", "minLength": 1},
    "canonical_value": {"type": "string", "minLength": 1},
    "original_value": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "locator": {"$ref": "source-locator.schema.json"}
  }
}
