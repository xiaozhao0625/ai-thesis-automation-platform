{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-fact-conflict.schema.json",
  "title": "ProjectFactConflict",
  "type": "object",
  "additionalProperties": false,
  "required": ["conflict_id", "task_id", "fact_id", "conflict_type", "status", "candidates", "auto_selection_allowed", "content_hash", "created_at"],
  "properties": {
    "conflict_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "fact_id": {"type": "string", "minLength": 1},
    "conflict_type": {"enum": ["USER_MATERIAL_CONFLICT", "USER_CODE_CONFLICT", "PUBLIC_SOURCE_CONFLICT"]},
    "status": {"enum": ["OPEN", "RESOLVED", "REJECTED"]},
    "candidates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_value", "source_link_ids"],
        "properties": {
          "canonical_value": {"type": "string", "minLength": 1},
          "source_link_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "auto_selection_allowed": {"const": false},
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "canonical_value", "selected_source_link_ids", "decided_by", "decided_at"],
      "properties": {
        "decision": {"enum": ["APPROVED", "REQUEST_CHANGES", "REJECTED"]},
        "canonical_value": {"type": "string", "minLength": 1},
        "selected_source_link_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "decided_by": {"type": "string", "minLength": 1},
        "decided_at": {"type": "string", "format": "date-time"}
      }
    },
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "RESOLVED"}}}, "then": {"required": ["resolution"]}},
    {"if": {"properties": {"status": {"const": "OPEN"}}}, "then": {"not": {"required": ["resolution"]}}}
  ]
}
