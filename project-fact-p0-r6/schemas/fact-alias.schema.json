{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fact-alias.schema.json",
  "title": "FactAlias",
  "type": "object",
  "additionalProperties": false,
  "required": ["alias_id", "fact_id", "fact_version_id", "alias_value", "scope", "status", "confirmed_by", "confirmed_at"],
  "properties": {
    "alias_id": {"type": "string", "minLength": 1},
    "fact_id": {"type": "string", "minLength": 1},
    "fact_version_id": {"type": "string", "minLength": 1},
    "alias_value": {"type": "string", "minLength": 1},
    "scope": {"enum": ["PROJECT_FACT_ONLY", "PROJECT_FACT_AND_PARAMETERS"]},
    "status": {"const": "APPROVED"},
    "confirmed_by": {"type": "string", "minLength": 1},
    "confirmed_at": {"type": "string", "format": "date-time"}
  }
}
