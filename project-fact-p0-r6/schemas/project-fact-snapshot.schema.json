{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-fact-snapshot.schema.json",
  "title": "ProjectFactSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["snapshot_id", "task_id", "version", "facts", "status", "snapshot_hash", "created_by", "created_at"],
  "properties": {
    "snapshot_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "facts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fact_id", "fact_version_id", "canonical_value", "fact_version_hash"],
        "properties": {
          "fact_id": {"type": "string", "minLength": 1},
          "fact_version_id": {"type": "string", "minLength": 1},
          "canonical_value": {"type": "string", "minLength": 1},
          "fact_version_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
        }
      }
    },
    "status": {"enum": ["ACTIVE", "SUSPENDED", "INVALIDATED", "SUPERSEDED"]},
    "snapshot_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
