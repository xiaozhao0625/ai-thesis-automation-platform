{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-event.schema.json",
  "title": "AuditEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["audit_event_id", "task_id", "event_type", "actor_id", "snapshot_id", "occurred_at"],
  "properties": {
    "audit_event_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "event_type": {"enum": ["PROJECT_FACT_INTAKE_CONFIRMED", "PROJECT_FACT_CONFLICT_RESOLVED"]},
    "actor_id": {"type": "string", "minLength": 1},
    "conflict_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "occurred_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"event_type": {"const": "PROJECT_FACT_CONFLICT_RESOLVED"}}}, "then": {"required": ["conflict_id", "reason"]}}
  ]
}
