{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "human-approval.schema.json",
  "title": "HumanApproval",
  "type": "object",
  "additionalProperties": false,
  "required": ["approval_id", "task_id", "approval_type", "status", "snapshot_id", "approved_by", "approved_at"],
  "properties": {
    "approval_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "approval_type": {"enum": ["PROJECT_FACT_INTAKE_CONFIRMATION", "PROJECT_FACT_CONFLICT_RESOLUTION"]},
    "status": {"const": "APPROVED"},
    "conflict_id": {"type": "string", "minLength": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "approved_by": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "approved_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"approval_type": {"const": "PROJECT_FACT_CONFLICT_RESOLUTION"}}}, "then": {"required": ["conflict_id", "reason"]}}
  ]
}
