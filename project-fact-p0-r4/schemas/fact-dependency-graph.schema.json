{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "fact-dependency-graph.schema.json",
  "title": "FactDependencyGraph",
  "type": "object",
  "additionalProperties": false,
  "required": ["root", "targets", "edges"],
  "properties": {
    "root": {"type": "string", "minLength": 1},
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_type", "target_id", "logical_id", "state"],
        "properties": {
          "target_type": {"enum": ["NODE_RUN", "CLAIM", "ARTIFACT_VERSION", "QUALITY_REPORT", "DELIVERY_PACKAGE"]},
          "target_id": {"type": "string", "minLength": 1},
          "logical_id": {"type": "string", "minLength": 1},
          "state": {"enum": ["SUCCEEDED", "READY", "QUEUED", "PENDING", "RUNNING", "WAITING_FOR_APPROVAL", "INVALIDATED"]}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [{"type": "string", "minLength": 1}, {"type": "string", "minLength": 1}],
        "minItems": 2,
        "maxItems": 2
      }
    }
  }
}
