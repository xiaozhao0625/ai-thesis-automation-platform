{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source-locator.schema.json",
  "title": "ProjectFactSourceLocator",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_version_id", "source_type", "file_path", "excerpt", "excerpt_hash"],
  "properties": {
    "artifact_version_id": {"type": "string", "minLength": 1},
    "source_type": {"enum": ["DOCX", "SOURCE_CODE", "SPREADSHEET", "IMAGE_OCR", "PDF"]},
    "file_path": {"type": "string", "minLength": 1},
    "excerpt": {"type": "string", "minLength": 1},
    "excerpt_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "page_number": {"type": "integer", "minimum": 1},
    "section": {"type": "string"},
    "paragraph_index": {"type": "integer", "minimum": 1},
    "char_start": {"type": "integer", "minimum": 0},
    "char_end": {"type": "integer", "minimum": 1},
    "commit": {"type": "string", "minLength": 1},
    "line_start": {"type": "integer", "minimum": 1},
    "line_end": {"type": "integer", "minimum": 1},
    "symbol_name": {"type": "string", "minLength": 1},
    "sheet_name": {"type": "string", "minLength": 1},
    "cell_range": {"type": "string", "minLength": 1},
    "page_index": {"type": "integer", "minimum": 0},
    "bbox": {
      "type": "array",
      "prefixItems": [{"type": "integer"}, {"type": "integer"}, {"type": "integer"}, {"type": "integer"}],
      "minItems": 4,
      "maxItems": 4
    },
    "ocr_block_id": {"type": "string", "minLength": 1},
    "ocr_text": {"type": "string", "minLength": 1},
    "ocr_text_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "image_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "text_block_id": {"type": "string"}
  },
  "allOf": [
    {"if": {"properties": {"source_type": {"const": "DOCX"}}}, "then": {"required": ["page_number", "section", "paragraph_index", "char_start", "char_end"]}},
    {"if": {"properties": {"source_type": {"const": "SOURCE_CODE"}}}, "then": {"required": ["commit", "line_start", "line_end", "symbol_name"]}},
    {"if": {"properties": {"source_type": {"const": "SPREADSHEET"}}}, "then": {"required": ["sheet_name", "cell_range"]}},
    {"if": {"properties": {"source_type": {"const": "IMAGE_OCR"}}}, "then": {"required": ["page_index", "bbox", "ocr_block_id", "ocr_text", "ocr_text_hash", "image_sha256"]}},
    {"if": {"properties": {"source_type": {"const": "PDF"}}}, "then": {"required": ["page_number", "text_block_id", "char_start", "char_end"]}}
  ]
}
