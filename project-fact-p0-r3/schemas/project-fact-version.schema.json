{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-fact-version.schema.json",
  "title": "ProjectFactVersion",
  "type": "object",
  "additionalProperties": false,
  "required": ["fact_version_id", "fact_id", "fact_key", "version", "canonical_value", "status", "locked", "source_link_ids", "content_hash", "confirmed_by", "confirmed_at"],
  "properties": {
    "fact_version_id": {"type": "string", "minLength": 1},
    "fact_id": {"type": "string", "minLength": 1},
    "fact_key": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "canonical_value": {"type": "string", "minLength": 1},
    "status": {"enum": ["LOCKED", "SUPERSEDED", "REJECTED"]},
    "locked": {"type": "boolean"},
    "source_link_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "supersedes_fact_version_id": {"type": ["string", "null"]},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "confirmed_by": {"type": "string", "minLength": 1},
    "confirmed_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "LOCKED"}}}, "then": {"properties": {"locked": {"const": true}}}},
    {"if": {"properties": {"status": {"const": "SUPERSEDED"}}}, "then": {"properties": {"locked": {"const": true}}}}
  ]
}
